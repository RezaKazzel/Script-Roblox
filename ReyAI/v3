function Utils.GetNearestEnemy(teamCheck)
	teamCheck = teamCheck or false
	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
	local myPos = char.HumanoidRootPart.Position
	local myTeam = teamCheck and LocalPlayer.Team or nil
	
	local nearest, nearestDist = nil, math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj ~= char then
			local hum = obj:FindFirstChild("Humanoid")
			local hrp = obj:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				local isNPC = true
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Character == obj then isNPC = false break end
				end
				
				if isNPC then
					local dist = (hrp.Position - myPos).Magnitude
					if dist < nearestDist then
						nearest, nearestDist = obj, dist
					end
				end
			end
		end
	end
	return nearest, nearestDist
end

function Utils.GetAllNPCs(radius)
	radius = radius or 100
	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
	local myPos = char.HumanoidRootPart.Position
	local npcs = {}
	
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj ~= char then
			local hum = obj:FindFirstChild("Humanoid")
			local hrp = obj:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				local isNPC = true
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Character == obj then isNPC = false break end
				end
				if isNPC then
					local dist = (hrp.Position - myPos).Magnitude
					if dist <= radius then
						table.insert(npcs, {
							Name = obj.Name,
							Health = hum.Health,
							MaxHealth = hum.MaxHealth,
							Position = {x = hrp.Position.X, y = hrp.Position.Y, z = hrp.Position.Z},
							Distance = dist,
							Instance = obj
						})
					end
				end
			end
		end
	end
	table.sort(npcs, function(a, b) return a.Distance < b.Distance end)
	return npcs
end

function Utils.KillAura(enable, range)
	if not enable then
		_G.KillAura = false
		return true
	end
	_G.KillAura = true
	range = range or 20
	_G.KillAuraLoop = coroutine.wrap(function()
		while _G.KillAura do
			local char = LocalPlayer.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				local npcs = Utils.GetAllNPCs(range)
				for _, npc in ipairs(npcs) do
					if not _G.KillAura then break end
					if npc.Instance and npc.Instance:FindFirstChild("Humanoid") then
						local hum = npc.Instance.Humanoid
						if hum.Health > 0 then
							char.HumanoidRootPart.CFrame = npc.Instance.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
							task.wait(0.1)
							-- Attack logic
							local tool = char:FindFirstChildOfClass("Tool")
							if tool and tool:FindFirstChild("Handle") then
								firetouchinterest(tool.Handle, npc.Instance:FindFirstChild("HumanoidRootPart"), 0)
								firetouchinterest(tool.Handle, npc.Instance:FindFirstChild("HumanoidRootPart"), 1)
							end
						end
					end
				end
			end
			task.wait()
		end
	end)
	_G.KillAuraLoop()
	return true
end

