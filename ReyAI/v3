-- ==== OPTIMIZED DETECTION SYSTEM (SINGLE LOOP) ====
local DetectionState = {
	promptedObjects = {},
	clickedObjects = {},
	knownMobs = {},
	lowHealthTriggered = false,
	lastPosition = nil,
	lastCurrency = {},
	lastMobCheck = 0,
	lastCurrencyCheck = 0
}

local function SendDetectionEvent(eventType, eventData)
	if not AI or not AI.IsActive then return end
	
	local enabledMap = {
	    ProximityPrompt = Utils.DetectionControl.promptEnabled,
	    ClickDetector = Utils.DetectionControl.clickDetectorEnabled,
	    MobSpawn = Utils.DetectionControl.mobSpawnEnabled,
	    LowHealth = Utils.DetectionControl.lowHealthEnabled,
	    Teleport = Utils.DetectionControl.teleportEnabled,
	    CurrencyChange = Utils.DetectionControl.currencyEnabled,
	    CustomDetection = true,
	    NearbyDetection = true
	}
	
	if enabledMap[eventType] == false then return end
	
	local HttpService = game:GetService("HttpService")
	local detectionMessage = string.format([[
[REY_SYSTEM:DETECTED]
{"type": "%s", "data": %s}
[/REY_SYSTEM:DETECTED]
]], eventType, HttpService:JSONEncode(eventData))
	
	task.spawn(function()
		AI:SendToAI(detectionMessage, 3, nil)
	end)
end

getgenv().SendDetectionEvent = SendDetectionEvent

coroutine.wrap(function()
	DetectionState.lastCurrency = Utils.GetCurrency()
	
	while true do
		local now = os.clock()
		local char = LocalPlayer.Character
		
		if char and char:FindFirstChild("HumanoidRootPart") then
			local hrp = char.HumanoidRootPart
			local currentPos = hrp.Position
			
			if DetectionState.lastPosition then
				local dist = (currentPos - DetectionState.lastPosition).Magnitude
				if dist > 200 then
					SendDetectionEvent("Teleport", {
						distance = math.floor(dist),
						to = {x = currentPos.X, y = currentPos.Y, z = currentPos.Z}
					})
				end
			end
			DetectionState.lastPosition = currentPos
			
			if now - DetectionState.lastMobCheck >= 3 then
				DetectionState.lastMobCheck = now
				local currentMobs = {}
				local newMobs = {}
				
				for _, obj in ipairs(workspace:GetDescendants()) do
					if obj:IsA("Model") and obj ~= char then
						local hum = obj:FindFirstChild("Humanoid")
						if hum and hum.Health > 0 then
							local isNPC = true
							for _, p in ipairs(Players:GetPlayers()) do
								if p.Character == obj then 
									isNPC = false 
									break 
								end
							end
							
							if isNPC then
								local key = obj:GetFullName()
								currentMobs[key] = {name = obj.Name}
								if not DetectionState.knownMobs[key] then
									table.insert(newMobs, {name = obj.Name})
								end
							end
						end
					end
				end
				
				if #newMobs > 0 then
					SendDetectionEvent("MobSpawn", {count = #newMobs, mobs = newMobs})
				end
				DetectionState.knownMobs = currentMobs
			end
			
			local hum = char:FindFirstChild("Humanoid")
			if hum then
				local percent = hum.Health / hum.MaxHealth
				if percent <= 0.25 and not DetectionState.lowHealthTriggered then
					DetectionState.lowHealthTriggered = true
					SendDetectionEvent("LowHealth", {
						health = hum.Health,
						maxHealth = hum.MaxHealth
					})
				elseif percent > 0.25 then
					DetectionState.lowHealthTriggered = false
				end
			end
		end
		
		if now - DetectionState.lastCurrencyCheck >= 2 then
			DetectionState.lastCurrencyCheck = now
			local currentCurrency = Utils.GetCurrency()
			
			for name, value in pairs(currentCurrency) do
				local oldValue = DetectionState.lastCurrency[name] or 0
				if value ~= oldValue then
					SendDetectionEvent("CurrencyChange", {
						currency = name,
						old = oldValue,
						new = value,
						change = value - oldValue
					})
				end
			end
			
			DetectionState.lastCurrency = currentCurrency
		end
		
		task.wait(0.5)
	end
end)()

local function hookClickDetector(obj)
	if not obj:IsA("ClickDetector") then return end
	local key = obj:GetFullName()
	if DetectionState.clickedObjects[key] or not Utils.DetectionControl.clickDetectorEnabled then return end
	DetectionState.clickedObjects[key] = true
	
	SendDetectionEvent("ClickDetector", {
		name = obj.Parent and obj.Parent.Name or "Unknown",
		path = key
	})
end

local shownPrompts = {}
local function hookProximityPrompt(prompt)
	local key = prompt:GetFullName()
	if shownPrompts[key] or not Utils.DetectionControl.promptEnabled then return end
	shownPrompts[key] = true
	
	SendDetectionEvent("ProximityPrompt", {
		name = prompt.Parent and prompt.Parent.Name or "Unknown",
		path = key,
		holdDuration = prompt.HoldDuration
	})
end

