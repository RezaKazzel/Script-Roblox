function Utils.DetectCustom(action, target, radius)
    action = action:lower()
    
    if action == "add" then
        if not target or target == "" then return false end
        
        local searchName = target:lower()
        local targetKey = searchName .. "_" .. (radius or 0)
        
        if Utils.CustomDetection.targets[targetKey] then return true end
        
        local function checkObject(obj)
            if obj.Name:lower():find(searchName, 1, true) or obj:GetFullName():lower():find(searchName, 1, true) then
                local pos = Utils.GetPosition(obj)
                if pos then
                    if radius then
                        local char = LocalPlayer.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            local dist = (Vector3.new(pos.x, pos.y, pos.z) - char.HumanoidRootPart.Position).Magnitude
                            if dist > radius then return end
                        end
                    end
                    
                    task.spawn(function()
                        local msg = string.format([[
[REY_SYSTEM:DETECTED]
{"type": "CustomDetection", "data": {"target": "%s", "name": "%s", "position": {"x": %s, "y": %s, "z": %s}}}
[/REY_SYSTEM:DETECTED]
]], target, obj.Name, pos.x, pos.y, pos.z)
                        AI:SendToAI(msg, 3, nil)
                    end)
                end
            end
        end
        
        for _, obj in ipairs(workspace:GetDescendants()) do
            checkObject(obj)
        end
        
        local conn = workspace.DescendantAdded:Connect(function(obj)
            task.wait(0.1)
            checkObject(obj)
        end)
        
        Utils.CustomDetection.targets[targetKey] = {
            name = target,
            radius = radius,
            connection = conn
        }
        
        return true
    end
    
    if action == "remove" then
        if not target or target == "" then return false end
        
        local searchName = target:lower()
        for key, data in pairs(Utils.CustomDetection.targets) do
            if data.name:lower() == searchName then
                if data.connection then
                    data.connection:Disconnect()
                end
                Utils.CustomDetection.targets[key] = nil
                return true
            end
        end
        return false
    end
    
    if action == "clear" then
        for _, data in pairs(Utils.CustomDetection.targets) do
            if data.connection then
                data.connection:Disconnect()
            end
        end
        Utils.CustomDetection.targets = {}
        return true
    end
    
    if action == "list" then
        local list = {}
        for _, data in pairs(Utils.CustomDetection.targets) do
            table.insert(list, {name = data.name, radius = data.radius})
        end
        return list
    end
    
    return false
end

function Utils.DetectNearby(target, radius, continuous)
    if not target or target == "" then return false end
    radius = radius or 50
    continuous = continuous or false
    
    local searchName = target:lower()
    local found = {}
    
    local function scan()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local myPos = char.HumanoidRootPart.Position
        
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name:lower():find(searchName, 1, true) then
                local pos = Utils.GetPosition(obj)
                if pos then
                    local objPos = Vector3.new(pos.x, pos.y, pos.z)
                    local dist = (objPos - myPos).Magnitude
                    if dist <= radius and not found[obj] then
                        found[obj] = true
                        task.spawn(function()
                            local msg = string.format([[
[REY_SYSTEM:DETECTED]
{"type": "NearbyDetection", "data": {"target": "%s", "name": "%s", "distance": %s, "position": {"x": %s, "y": %s, "z": %s}}}
[/REY_SYSTEM:DETECTED]
]], target, obj.Name, math.floor(dist), pos.x, pos.y, pos.z)
                            AI:SendToAI(msg, 3, nil)
                        end)
                    end
                end
            end
        end
    end
    
    scan()
    
    if continuous then
        _G.NearbyDetectionLoop = coroutine.wrap(function()
            while _G.NearbyDetectionEnabled do
                scan()
                task.wait(1)
            end
        end)
        _G.NearbyDetectionEnabled = true
        _G.NearbyDetectionLoop()
    end
    
    return true
end

function Utils.StopNearbyDetection()
    _G.NearbyDetectionEnabled = false
    return true
end

