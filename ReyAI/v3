function Utils.FindPlayer(name)
    if not name or name == "" then return nil end
    local searchName = name:lower()
    local foundPlayer = nil
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name:lower() == searchName or player.DisplayName:lower() == searchName then
            return player
        end
        if player.Name:lower():sub(1, #searchName) == searchName or 
           player.DisplayName:lower():sub(1, #searchName) == searchName then
            foundPlayer = player
        end
    end
    
    if not foundPlayer then
        local success, userId = pcall(function()
            return Players:GetUserIdFromNameAsync(searchName)
        end)
        if success and userId then
            return {UserId = userId, Name = name}
        end
    end
    
    return foundPlayer
end

function Utils.FindInWorkspace(name)
    if not name or name == "" then return {} end
    local searchName = name:lower()
    local matches = {}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find(searchName, 1, true) then
            local pos = nil
            if obj:IsA("BasePart") then
                pos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                pos = obj.PrimaryPart.Position
            elseif obj:GetPivot() then
                pos = obj:GetPivot().Position
            end
            table.insert(matches, {
                Name = obj.Name,
                Class = obj.ClassName,
                Position = pos and {x = pos.X, y = pos.Y, z = pos.Z} or nil,
                Instance = obj
            })
        end
    end
    return matches
end

function Utils.GetPosition(target)
    if not target then return nil end
    if typeof(target) == "Instance" then
        if target:IsA("Player") then
            local char = target.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos = char.HumanoidRootPart.Position
                return {x = pos.X, y = pos.Y, z = pos.Z}
            end
        elseif target:IsA("BasePart") then
            return {x = target.Position.X, y = target.Position.Y, z = target.Position.Z}
        elseif target:IsA("Model") and target.PrimaryPart then
            local pos = target.PrimaryPart.Position
            return {x = pos.X, y = pos.Y, z = pos.Z}
        end
    elseif type(target) == "table" and target.x and target.y and target.z then
        return target
    end
    return nil
end

function Utils.GetNearestPlayer()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    
    local nearest, nearestDist = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local dist = (targetChar.HumanoidRootPart.Position - myPos).Magnitude
                if dist < nearestDist then
                    nearest, nearestDist = player, dist
                end
            end
        end
    end
    return nearest, nearestDist
end

