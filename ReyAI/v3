function Utils.GetDate()
    local t = os.date("*t")
    local days = {"Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"}
    local months = {"January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"}
    return {
        day = t.day,
        month = t.month,
        monthName = months[t.month],
        year = t.year,
        weekday = days[t.wday],
        dateString = string.format("%02d/%02d/%d", t.day, t.month, t.year)
    }
end

function Utils.TeleportTo(target, useTween)
    useTween = useTween or false
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    
    local pos = nil
    if type(target) == "table" and target.x and target.y and target.z then
        pos = Vector3.new(target.x, target.y, target.z)
    elseif typeof(target) == "Instance" then
        if target:IsA("Player") then
            local targetChar = target.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                pos = targetChar.HumanoidRootPart.Position
            end
        elseif target:IsA("BasePart") then
            pos = target.Position
        elseif target:IsA("Model") and target.PrimaryPart then
            pos = target.PrimaryPart.Position
        end
    end
    
    if not pos then return false end
    
    local hrp = char.HumanoidRootPart
    
    if useTween then
        local TweenService = game:GetService("TweenService")
        local dist = (hrp.Position - pos).Magnitude
        local tweenInfo = TweenInfo.new(
            math.clamp(dist / 100, 0.3, 3),
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out
        )
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(pos)})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = CFrame.new(pos)
    end
    
    return true
end

function Utils.TeleportToPath(path, useTween)
    local success, obj = pcall(function()
        return loadstring("return " .. path)()
    end)
    
    if not success or not obj then
        local parts = {}
        for part in string.gmatch(path, "[^%.]+") do
            table.insert(parts, part)
        end
        
        obj = workspace
        for _, name in ipairs(parts) do
            if obj then
                obj = obj:FindFirstChild(name)
            end
        end
    end
    
    if not obj then return false, "Path not found" end
    
    local pos = nil
    if obj:IsA("BasePart") then
        pos = obj.Position
    elseif obj:IsA("Model") then
        local primary = obj.PrimaryPart
        if primary then
            pos = primary.Position
        elseif obj:FindFirstChild("HumanoidRootPart") then
            pos = obj.HumanoidRootPart.Position
        else
            pos = obj:GetPivot().Position
        end
    end
    
    if not pos then return false, "Cannot get position" end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        return false, "Character not ready" 
    end
    
    local hrp = char.HumanoidRootPart
    
    if useTween then
        local TweenService = game:GetService("TweenService")
        local dist = (hrp.Position - pos).Magnitude
        local tweenInfo = TweenInfo.new(
            math.clamp(dist / 100, 0.3, 3),
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out
        )
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(pos)})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = CFrame.new(pos)
    end
    
    return true, obj.Name, pos
end

function Utils.TeleportToObject(name, useTween)
    local matches = Utils.FindInWorkspace(name)
    if #matches == 0 then return false, "Object not found" end
    
    local target = matches[1].Instance
    local pos = nil
    
    if target:IsA("BasePart") then
        pos = target.Position
    elseif target:IsA("Model") then
        local primary = target.PrimaryPart
        if primary then
            pos = primary.Position
        else
            local hum = target:FindFirstChild("Humanoid")
            if hum and hum.RootPart then
                pos = hum.RootPart.Position
            else
                pos = target:GetPivot().Position
            end
        end
    elseif target:GetPivot then
        pos = target:GetPivot().Position
    end
    
    if not pos then return false, "Cannot get position" end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        return false, "Character not ready" 
    end
    
    local hrp = char.HumanoidRootPart
    
    if useTween then
        local TweenService = game:GetService("TweenService")
        local tweenInfo = TweenInfo.new(
            (hrp.Position - pos).Magnitude / 100,
            Enum.EasingStyle.Linear,
            Enum.EasingDirection.Out
        )
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(pos)})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = CFrame.new(pos)
    end
    
    return true, target.Name, pos
end

function Utils.TeleportToNearest(name, useTween)
    local nearest, dist = Utils.GetNearestObject(name)
    if not nearest then return false, "Object not found" end
    
    local pos = nearest.Position
    if not pos then return false, "Cannot get position" end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        return false, "Character not ready" 
    end
    
    local hrp = char.HumanoidRootPart
    local targetPos = Vector3.new(pos.x, pos.y, pos.z)
    
    if useTween then
        local TweenService = game:GetService("TweenService")
        local tweenInfo = TweenInfo.new(
            math.clamp(dist / 100, 0.5, 3),
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out
        )
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = CFrame.new(targetPos)
    end
    
    return true, nearest.Name, targetPos, dist
end

function Utils.GetNearestObject(name)
    local matches = Utils.FindInWorkspace(name)
    if #matches == 0 then return nil end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return matches[1] end
    
    local myPos = char.HumanoidRootPart.Position
    local nearest, nearestDist = nil, math.huge
    
    for _, obj in ipairs(matches) do
        if obj.Position then
            local objPos = Vector3.new(obj.Position.x, obj.Position.y, obj.Position.z)
            local dist = (objPos - myPos).Magnitude
            if dist < nearestDist then
                nearest, nearestDist = obj, dist
            end
        end
    end
    return nearest, nearestDist
end

function Utils.GetPlayersInRadius(radius)
    radius = radius or 50
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
    local myPos = char.HumanoidRootPart.Position
    
    local nearby = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local dist = (targetChar.HumanoidRootPart.Position - myPos).Magnitude
                if dist <= radius then
                    table.insert(nearby, {
                        Name = player.Name,
                        DisplayName = player.DisplayName,
                        Distance = dist
                    })
                end
            end
        end
    end
    table.sort(nearby, function(a, b) return a.Distance < b.Distance end)
    return nearby
end

