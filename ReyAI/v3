function Utils.MusicControl(action, value)
    action = action:lower()
    
    if action == "search" then
        local query = value
        local url = "https://api.ryzumi.net/api/search/yt?query=" .. game:GetService("HttpService"):UrlEncode(query)
        local success, response = pcall(function() return game:HttpGet(url) end)
        if not success then return nil end
        local data = game:GetService("HttpService"):JSONDecode(response)
        
        local results = {}
        for _, v in pairs(data.videos) do
            table.insert(results, {
                id = v.id,
                title = v.title,
                author = v.author and v.author.name or "Unknown",
                duration = v.duration and v.duration.timestamp or "?:??"
            })
        end
        
        Utils.Music.lastSearch = results
        return results
    end
    
    if action == "download" then
        local index = tonumber(value)
        local v = Utils.Music.lastSearch[index]
        if not v then return false end
        
        if Utils.Music.downloads[v.id] then return false end
        Utils.Music.downloads[v.id] = true
        
        local url = "https://api.ryzumi.net/api/downloader/ytmp3?url=https://youtube.com/watch?v=" .. v.id
        local success, response = pcall(function() return game:HttpGet(url) end)
        if not success then Utils.Music.downloads[v.id] = nil return false end
        
        local data = game:GetService("HttpService"):JSONDecode(response)
        local audioSuccess, audioData = pcall(function() return game:HttpGet(data.url) end)
        if not audioSuccess then Utils.Music.downloads[v.id] = nil return false end
        
        local folder = "ReyHub/Music/"
        if not isfolder(folder) then makefolder(folder) end
        local safeTitle = v.title:gsub("[^%w%s]", ""):gsub("%s+", "_")
        local filePath = folder .. safeTitle .. ".mp3"
        writefile(filePath, audioData)
        
        Utils.Music.downloads[v.id] = nil
        return {success = true, title = v.title, path = filePath}
    end
    
    if action == "play" then
        local title = value
        local folder = "ReyHub/Music/"
        local files = listfiles(folder)
        
        for _, file in ipairs(files) do
            if file:match("%.mp3$") then
                local name = file:match("([^/]+)%.mp3$"):gsub("_", " "):lower()
                if name:find(title:lower(), 1, true) then
                    if Utils.Music.sound then
                        Utils.Music.sound:Stop()
                        Utils.Music.sound:Destroy()
                    end
                    
                    local sound = Instance.new("Sound")
                    sound.SoundId = getcustomasset(file)
                    sound.Volume = Utils.Music.volume
                    sound.Parent = game.Players.LocalPlayer.PlayerGui
                    
                    sound.Ended:Connect(function()
                        if Utils.Music.loop then
                            Utils.MusicControl("play", title)
                        end
                    end)
                    
                    sound:Play()
                    Utils.Music.sound = sound
                    return {success = true, name = name}
                end
            end
        end
        return {success = false}
    end
    
    if action == "pause" then
        if Utils.Music.sound then
            Utils.Music.sound:Pause()
            return true
        end
        return false
    end
    
    if action == "resume" then
        if Utils.Music.sound then
            Utils.Music.sound:Resume()
            return true
        end
        return false
    end
    
    if action == "stop" then
        if Utils.Music.sound then
            Utils.Music.sound:Stop()
            Utils.Music.sound:Destroy()
            Utils.Music.sound = nil
            return true
        end
        return false
    end
    
    if action == "volume" then
        Utils.Music.volume = math.clamp(tonumber(value) / 100, 0, 1)
        if Utils.Music.sound then
            Utils.Music.sound.Volume = Utils.Music.volume
        end
        return true
    end
    
    if action == "loop" then
        Utils.Music.loop = value == true
        return true
    end
    
    if action == "library" then
        local folder = "ReyHub/Music/"
        if not isfolder(folder) then return {} end
        local files = listfiles(folder)
        local songs = {}
        for _, file in ipairs(files) do
            if file:match("%.mp3$") then
                local name = file:match("([^/]+)%.mp3$"):gsub("_", " ")
                table.insert(songs, name)
            end
        end
        return songs
    end
    
    return false
end

