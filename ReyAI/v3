function Utils.Highlight(target, color, duration)
	if not target then return false end
	local instance = nil
	if typeof(target) == "Instance" then
		instance = target
	elseif type(target) == "table" and target.Instance then
		instance = target.Instance
	elseif type(target) == "string" then
		local matches = Utils.FindInWorkspace(target)
		instance = matches[1] and matches[1].Instance
	end
	if not instance then return false end
	
	local highlight = Instance.new("Highlight")
	highlight.FillColor = typeof(color) == "Color3" and color or Color3.fromHex(color or "#FF0000")
	highlight.FillTransparency = 0.5
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	highlight.Parent = instance
	
	if duration then
		task.delay(duration, function()
			pcall(function() highlight:Destroy() end)
		end)
	end
	return highlight
end

function Utils.ESP(enable, settings)
	settings = settings or {}
	if not enable then
		if _G.ESPConnections then
			for _, conn in ipairs(_G.ESPConnections) do 
				pcall(function() conn:Disconnect() end) 
			end
			_G.ESPConnections = nil
		end
		for _, v in ipairs(workspace:GetDescendants()) do
			if v.Name == "_REY_ESP_HIGHLIGHT" then 
				pcall(function() v:Destroy() end) 
			end
		end
		return true
	end
	
	local function createESP(player)
		local char = player.Character
		if not char then return end
		task.wait(0.1)
		if not char.Parent then return end
		
		local highlight = Instance.new("Highlight")
		highlight.Name = "_REY_ESP_HIGHLIGHT"
		highlight.FillColor = Color3.fromHex(settings.Color or "#FF0000")
		highlight.FillTransparency = 0.5
		highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
		highlight.Adornee = char
		highlight.Parent = char
		
		local billboard = Instance.new("BillboardGui")
		billboard.Name = "_REY_ESP_HIGHLIGHT"
		billboard.Adornee = char:FindFirstChild("Head") or char:FindFirstChildWhichIsA("BasePart")
		billboard.Size = UDim2.new(0, 100, 0, 50)
		billboard.StudsOffset = Vector3.new(0, 3, 0)
		billboard.AlwaysOnTop = true
		billboard.Parent = char
		
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeTransparency = 0
		label.Text = player.Name
		label.Parent = billboard
		
		local hum = char:FindFirstChild("Humanoid")
		if hum then
			hum.Died:Connect(function()
				pcall(function() highlight:Destroy() end)
				pcall(function() billboard:Destroy() end)
			end)
		end
	end
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			p.CharacterAdded:Connect(function(char) 
				task.wait(0.5) 
				createESP(p) 
			end)
			if p.Character then createESP(p) end
		end
	end
	
	_G.ESPConnections = {}
	table.insert(_G.ESPConnections, Players.PlayerAdded:Connect(function(p)
		p.CharacterAdded:Connect(function(char) 
			task.wait(0.5) 
			createESP(p) 
		end)
	end))
	return true
end

