Utils.GuiDetectionState = {
	mode = "onClick",
	hookedButtons = {},
	lastDetectedPath = "",
	lastDetectedGui = nil,
	autoClickEnabled = false,
	autoClickTarget = nil,
	recordEnabled = false,
	recordedActions = {},
	descendantConnection = nil
}

function Utils.IsActuallyVisible(gui)
	if not gui or not gui:IsDescendantOf(LocalPlayer.PlayerGui) then 
		return false 
	end
	if gui:IsA("GuiObject") and (gui.AbsoluteSize.X <= 0 or gui.AbsoluteSize.Y <= 0) then 
		return false 
	end
	
	local current = gui
	while current and current ~= LocalPlayer.PlayerGui do
		if current:IsA("ScreenGui") and current.Enabled == false then 
			return false 
		end
		if current:IsA("GuiObject") and current.Visible == false then 
			return false 
		end
		current = current.Parent
	end
	return true
end

function Utils.ClickGUI(gui)
	if not gui then return false end
	
	local methods = {
		{func = function() 
			if gui.MouseButton1Click then 
				firesignal(gui.MouseButton1Click, LocalPlayer) 
			end
		end},
		{func = function() 
			if gui.MouseButton1Click then 
				firesignal(gui.MouseButton1Click) 
			end
		end},
		{func = function() 
			if getconnections then
				for _, v in pairs(getconnections(gui.MouseButton1Down)) do 
					if v.Function then v.Function() end
				end
			end
		end},
		{func = function() 
			if getconnections then
				for _, v in pairs(getconnections(gui.MouseButton1Down)) do 
					if v.Fire then v:Fire() end
				end
			end
		end},
		{func = function() 
			if gui.MouseButton1Click and replicatesignal then 
				replicatesignal(gui.MouseButton1Click) 
			end
		end},
		{func = function()
			gui:Activate()
		end}
	}
	
	for _, method in ipairs(methods) do
		local success = pcall(method.func)
		if success then return true end
	end
	
	return false
end

function Utils.FindGUI(name)
	if not name or name == "" then return nil end
	local searchName = name:lower()
	local matches = {}
	
	for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
		if gui.Name:lower():find(searchName, 1, true) and gui:IsA("GuiObject") then
			if Utils.IsActuallyVisible(gui) then
				return gui
			else
				table.insert(matches, gui)
			end
		end
	end
	
	return matches[1]
end

function Utils.OpenGUI(name)
	local gui = Utils.FindGUI(name)
	if gui then
		if gui:IsA("ScreenGui") then
			gui.Enabled = true
			return true
		elseif gui:IsA("GuiObject") then
			gui.Visible = true
			return Utils.ClickGUI(gui)
		end
	end
	return false
end

function Utils.StartGUIDetection(mode)
	mode = mode or "onClick"
	Utils.GuiDetectionState.mode = mode
	
	if Utils.GuiDetectionState.descendantConnection then
		Utils.GuiDetectionState.descendantConnection:Disconnect()
	end
	
	local function hookButton(gui)
		if not (gui:IsA("TextButton") or gui:IsA("ImageButton")) then 
			return 
		end
		
		if Utils.GuiDetectionState.hookedButtons[gui] then 
			return 
		end
		
		Utils.GuiDetectionState.hookedButtons[gui] = true
		
		local function onDetected()
			if Utils.IsActuallyVisible(gui) then
				Utils.GuiDetectionState.lastDetectedPath = gui:GetFullName()
				Utils.GuiDetectionState.lastDetectedGui = gui
				
				if Utils.GuiDetectionState.recordEnabled then
					table.insert(Utils.GuiDetectionState.recordedActions, {
						type = "click",
						path = gui:GetFullName(),
						time = os.clock()
					})
				end
				
				if Utils.GuiDetectionState.autoClickEnabled and 
				   Utils.GuiDetectionState.autoClickTarget and 
				   gui:GetFullName():find(Utils.GuiDetectionState.autoClickTarget, 1, true) then
					task.wait(0.05)
					Utils.ClickGUI(gui)
				end
			end
		end
		
		if Utils.GuiDetectionState.mode == "onClick" then
			gui.MouseButton1Click:Connect(onDetected)
			gui.MouseButton1Down:Connect(onDetected)
		else
			gui.MouseEnter:Connect(onDetected)
		end
	end
	
	for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
		hookButton(gui)
	end
	
	Utils.GuiDetectionState.descendantConnection = LocalPlayer.PlayerGui.DescendantAdded:Connect(function(gui)
		task.wait(0.1)
		hookButton(gui)
	end)
	
	return true
end

function Utils.StopGUIDetection()
	if Utils.GuiDetectionState.descendantConnection then
		Utils.GuiDetectionState.descendantConnection:Disconnect()
		Utils.GuiDetectionState.descendantConnection = nil
	end
	Utils.GuiDetectionState.hookedButtons = {}
	Utils.GuiDetectionState.autoClickEnabled = false
	Utils.GuiDetectionState.recordEnabled = false
	return true
end

function Utils.AutoClickGUI(target)
	Utils.GuiDetectionState.autoClickEnabled = true
	Utils.GuiDetectionState.autoClickTarget = target
	Utils.StartGUIDetection("onClick")
	return true
end

function Utils.StopAutoClick()
	Utils.GuiDetectionState.autoClickEnabled = false
	Utils.GuiDetectionState.autoClickTarget = nil
	return true
end

function Utils.StartRecord()
	Utils.GuiDetectionState.recordEnabled = true
	Utils.GuiDetectionState.recordedActions = {}
	Utils.StartGUIDetection("onClick")
	return true
end

function Utils.StopRecord()
	Utils.GuiDetectionState.recordEnabled = false
	return Utils.GuiDetectionState.recordedActions
end

function Utils.PlayRecord(actions, speed)
	actions = actions or Utils.GuiDetectionState.recordedActions
	speed = speed or 1
	_G.PlayRecordLoop = coroutine.wrap(function()
		local lastTime = nil
		for _, action in ipairs(actions) do
			if lastTime then
				local waitTime = (action.time - lastTime) / speed
				if waitTime > 0 then task.wait(waitTime) end
			end
			local gui = Utils.FindGUIByPath(action.path)
			if gui then
				Utils.ClickGUI(gui)
			end
			lastTime = action.time
		end
	end)
	_G.PlayRecordLoop()
	return true
end

function Utils.FindGUIByPath(path)
	local success, gui = pcall(function()
		return loadstring("return " .. path)()
	end)
	if success and gui then return gui end
	
	local parts = {}
	for part in string.gmatch(path, "[^%.]+") do
		table.insert(parts, part)
	end
	
	local obj = LocalPlayer.PlayerGui
	for _, name in ipairs(parts) do
		if obj then
			obj = obj:FindFirstChild(name)
		end
	end
	return obj
end

-- ==== PROXIMITY PROMPT & CLICK DETECTOR ====
function Utils.ProximityPrompt(action, value)
    action = action:lower()
    
    if action == "instant" then
        if value == true then
            if _G.InstantPromptConn then return true end
            _G.InstantPromptEnabled = true
            
            local function makeInstant(prompt)
                if prompt.HoldDuration > 0 then
                    prompt.HoldDuration = 0
                end
            end
            
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    makeInstant(obj)
                end
            end
            
            _G.InstantPromptConn = workspace.DescendantAdded:Connect(function(obj)
                if obj:IsA("ProximityPrompt") and _G.InstantPromptEnabled then
                    makeInstant(obj)
                end
            end)
        else
            _G.InstantPromptEnabled = false
            if _G.InstantPromptConn then
                _G.InstantPromptConn:Disconnect()
                _G.InstantPromptConn = nil
            end
        end
        return true
    end
    
    if action == "auto" then
        if value == true then
            if _G.AutoPromptConn then return true end
            _G.AutoPromptEnabled = true
            
            local function autoFire(prompt)
                task.wait(0.05)
                pcall(function()
                    fireproximityprompt(prompt, 0)
                end)
            end
            
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    obj.PromptShown:Connect(function()
                        if _G.AutoPromptEnabled then
                            autoFire(obj)
                        end
                    end)
                end
            end
            
            _G.AutoPromptConn = workspace.DescendantAdded:Connect(function(obj)
                if obj:IsA("ProximityPrompt") then
                    obj.PromptShown:Connect(function()
                        if _G.AutoPromptEnabled then
                            autoFire(obj)
                        end
                    end)
                end
            end)
        else
            _G.AutoPromptEnabled = false
            if _G.AutoPromptConn then
                _G.AutoPromptConn:Disconnect()
                _G.AutoPromptConn = nil
            end
        end
        return true
    end
    
    if action == "fire" then
        local target = value
        if type(target) == "string" then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.Parent and obj.Parent.Name:lower():find(target:lower(), 1, true) then
                    pcall(function()
                        fireproximityprompt(obj, 0)
                    end)
                    return true
                end
            end
        elseif typeof(target) == "Instance" and target:IsA("ProximityPrompt") then
            pcall(function()
                fireproximityprompt(target, 0)
            end)
            return true
        end
        return false
    end
    
    if action == "fireall" then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                pcall(function()
                    fireproximityprompt(obj, 0)
                end)
            end
        end
        return true
    end
    
    if action == "hook" then
        if value == true then
            if _G.HookPromptConn then return true end
            _G.HookPromptEnabled = true
            _G.PromptCounter = _G.PromptCounter or {}
            
            local function hook(prompt)
                local parent = prompt.Parent
                local key = parent and parent:GetFullName() or prompt:GetFullName()
                _G.PromptCounter[key] = (_G.PromptCounter[key] or 0) + 1
                
                if _G.PromptCounter[key] == 1 then
                    Utils.Notification("ReyAI", "Proximity Prompt: " .. (parent and parent.Name or "Unknown"))
                end
            end
            
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    hook(obj)
                end
            end
            
            _G.HookPromptConn = workspace.DescendantAdded:Connect(function(obj)
                if obj:IsA("ProximityPrompt") and _G.HookPromptEnabled then
                    hook(obj)
                end
            end)
        else
            _G.HookPromptEnabled = false
            if _G.HookPromptConn then
                _G.HookPromptConn:Disconnect()
                _G.HookPromptConn = nil
            end
            _G.PromptCounter = {}
        end
        return true
    end
    
    return false
end

function Utils.HookClickDetectors(enable, autoClick)
	if not enable then
		if _G.ClickDetectorConn then
			_G.ClickDetectorConn:Disconnect()
			_G.ClickDetectorConn = nil
		end
		_G.AutoClickDetector = false
		return true
	end
	
	_G.AutoClickDetector = autoClick or false
	_G.ClickCounter = _G.ClickCounter or {}
	
	_G.ClickDetectorConn = workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("ClickDetector") then
			local parent = obj.Parent
			local key = parent and parent:GetFullName() or obj:GetFullName()
			_G.ClickCounter[key] = (_G.ClickCounter[key] or 0) + 1
			
			if _G.AutoClickDetector then
				task.wait(0.05)
				pcall(function()
					fireclickdetector(obj)
				end)
			end
			
			if _G.ClickCounter[key] <= 3 then
				Utils.Notification("ReyAI", "ClickDetector: " .. (parent and parent.Name or "Unknown") .. " (" .. _G.ClickCounter[key] .. "x)")
			end
		end
	end)
	
	return true
end

-- ==== MOB/WORKSPACE DETECTION NOTIFICATION ====
function Utils.MonitorWorkspace(enable, keyword, interval)
	if not enable then
		if _G.WorkspaceMonitorConn then
			_G.WorkspaceMonitorConn:Disconnect()
			_G.WorkspaceMonitorConn = nil
		end
		_G.MonitoredObjects = nil
		return true
	end
	
	keyword = keyword or "mob"
	interval = interval or 2
	_G.MonitoredObjects = {}
	
	_G.WorkspaceMonitorConn = coroutine.wrap(function()
		while true do
			local currentObjects = {}
			local newCount = 0
			
			for _, obj in ipairs(workspace:GetDescendants()) do
				if obj.Name:lower():find(keyword:lower(), 1, true) then
					local key = obj:GetFullName()
					currentObjects[key] = true
					if not _G.MonitoredObjects[key] then
						newCount = newCount + 1
					end
				end
			end
			
			if newCount > 0 then
				Utils.Notification("ReyAI", "Detected " .. newCount .. " new " .. keyword .. "(s)", 3)
			end
			
			_G.MonitoredObjects = currentObjects
			task.wait(interval)
		end
	end)
	_G.WorkspaceMonitorConn()
	return true
end

