local function GetActiveScriptsList()
	local list = ""
	for k, v in pairs(_G) do
		if typeof(v) == "RBXScriptConnection" then
			list = list .. "_G." .. tostring(k) .. " = Connection (active)\n"
		elseif type(v) == "thread" then
			local status = coroutine.status(v)
			if status == "running" or status == "suspended" then
				list = list .. "_G." .. tostring(k) .. " = Thread (" .. status .. ")\n"
			else
				list = list .. "_G." .. tostring(k) .. " = Thread (dead)\n"
			end
		elseif type(v) == "boolean" and v == true then
			if string.find(string.lower(k), "auto") or string.find(string.lower(k), "loop") then
				list = list .. "_G." .. tostring(k) .. " = true (Loop Toggle)\n"
			else
				list = list .. "_G." .. tostring(k) .. " = true\n"
			end
		elseif type(v) == "table" and v ~= _G then
			if string.find(string.lower(k), "original") or string.find(string.lower(k), "backup") then
				list = list .. "_G." .. tostring(k) .. " = Table (Backup Data)\n"
			end
		end
	end
	if list == "" then
		list = "No active scripts or stored data\n"
	end
	return list
end

