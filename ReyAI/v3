Utils.KillState = {
	threshold = 0.9,
	buttons = {V1 = nil, V2 = nil, V3 = nil},
	autoV4 = false,
	autoV5 = false,
	v4Conn = nil,
	v5Conn = nil,
	v5Loop = nil,
	hooked = {}
}

function Utils.Kill(action, value)
	action = action:lower()
	
	if action == "threshold" then
		Utils.KillState.threshold = math.clamp((tonumber(value) or 90) / 100, 0.01, 1)
		return true
	end
	
	if action == "v1" or action == "v2" or action == "v3" then
		local ver = action:sub(2,2)
		if value == true then
			if Utils.KillState.buttons["V"..ver] then
				Utils.KillState.buttons["V"..ver]:Destroy()
			end
			local sg = Instance.new("ScreenGui")
			sg.Name = "KillV"..ver
			sg.Parent = game:GetService("CoreGui")
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 80, 0, 35)
			btn.Position = UDim2.new(1, -140, 0, 10 + ((tonumber(ver)-1)*40))
			btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			btn.Text = "KILL V"..ver
			btn.TextColor3 = Color3.new(1, 0, 0)
			btn.BorderSizePixel = 0
			btn.Font = Enum.Font.GothamBold
			btn.TextSize = 14
			btn.Parent = sg
			btn.Active = true
			btn.Draggable = true
			btn.MouseButton1Click:Connect(function()
				pcall(function()
					sethiddenproperty(LocalPlayer, "SimulationRadius", 112412400000)
					sethiddenproperty(LocalPlayer, "MaxSimulationRadius", 112412400000)
				end)
				for _, obj in ipairs(workspace:GetDescendants()) do
					if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") and obj.Parent.Name ~= LocalPlayer.Name then
						if ver == "1" and obj.Health < obj.MaxHealth then obj.Health = 0 end
						if ver == "2" and obj.Health < obj.MaxHealth then obj.Parent:BreakJoints() end
						if ver == "3" then obj.Health = 0 end
					end
				end
			end)
			Utils.KillState.buttons["V"..ver] = sg
		else
			if Utils.KillState.buttons["V"..ver] then
				Utils.KillState.buttons["V"..ver]:Destroy()
				Utils.KillState.buttons["V"..ver] = nil
			end
		end
		return true
	end
	
	if action == "v4" then
		if value == true then
			if Utils.KillState.v4Conn then return true end
			Utils.KillState.autoV4 = true
			local function hook(hum)
				if Utils.KillState.hooked[hum] then return end
				Utils.KillState.hooked[hum] = hum.HealthChanged:Connect(function()
					if not Utils.KillState.autoV4 then return end
					local m = hum.Parent
					if m and m:IsA("Model") and m.Name ~= LocalPlayer.Name and hum.Health > 0 then
						if hum.Health / math.max(hum.MaxHealth, 1) < Utils.KillState.threshold then
							hum.Health = 0
							m:BreakJoints()
						end
					end
				end)
			end
			for _, v in ipairs(workspace:GetDescendants()) do
				if v:IsA("Humanoid") then hook(v) end
			end
			Utils.KillState.v4Conn = workspace.DescendantAdded:Connect(function(v)
				if v:IsA("Humanoid") then task.wait() hook(v) end
			end)
		else
			Utils.KillState.autoV4 = false
			if Utils.KillState.v4Conn then
				Utils.KillState.v4Conn:Disconnect()
				Utils.KillState.v4Conn = nil
			end
			for _, c in pairs(Utils.KillState.hooked) do pcall(function() c:Disconnect() end) end
			Utils.KillState.hooked = {}
		end
		return true
	end
	
	if action == "v5" then
		if value == true then
			if Utils.KillState.autoV5 then return true end
			Utils.KillState.autoV5 = true
			local humans = {}
			for _, v in ipairs(workspace:GetDescendants()) do
				if v:IsA("Humanoid") and v.Parent and v.Parent:IsA("Model") and v.Parent.Name ~= LocalPlayer.Name then
