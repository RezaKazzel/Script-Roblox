function ReyAIChat.new(settings)
    local self = setmetatable({}, ReyAIChat)
    
    self.CommandPrefix = (settings and settings.CommandPrefix) or "?"
    self.Notify = settings and settings.NotifyFunc or function() end
    self.OnAIResponse = settings and settings.OnAIResponse or function(code) loadstring(code)() end
    self.HttpFunc = settings and settings.HttpFunc
    
    self.ChatEnabled = false
    self.LegacyConnection = nil
    self.PlayerChatConnection = nil
    self.ExperienceConnections = {}
    self.ConversationHistory = nil
    
    return self
end

function ReyAIChat:Enable()
    if self.ChatEnabled then return true end
    
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    
    self.IsActive = false
    
    local function onMessageReceived(message, speaker)
        local msgLower = message:lower()
        local isFromOther = speaker and speaker ~= LocalPlayer
        print(message)
        if string.find(msgLower, "rey off") or string.find(msgLower, "rey stop") then
            if not isFromOther or PublicFull then
                self.IsActive = false
                Public = false
                PublicFull = false
                self.Notify("info", "ReyAI", "AI Deactivated")
                if PublicFull then sendMessage("[Rey] Deactivated") end
            end
            return true
        elseif string.find(msgLower, "rey public full") then
            if not isFromOther or PublicFull then
                Public = true
                PublicFull = true
                self.Notify("info", "ReyAI", "Public Full mode enabled")
            end
            return true
        elseif string.find(msgLower, "rey public") then
            if not isFromOther or PublicFull or Public then
                Public = true
                self.Notify("info", "ReyAI", "You chat now is Public")
            end
            return true
        elseif string.find(msgLower, "rey") and not self.IsActive then
            if not isFromOther or PublicFull then
                self.IsActive = true
                self.Notify("success", "ReyAI", "AI Activated")
                if PublicFull then sendMessage("[Rey] Activated") end
            end
            return true
        end
        
        if self.IsActive then
            if isFromOther and not PublicFull then
                return false
            end
            return true
        end
        
        return false
    end
    
    self.LegacyConnection = LocalPlayer.Chatted:Connect(function(message, recipient)
        onMessageReceived(message, LocalPlayer)
    end)
    
    self.PlayerChatConnection = Players.PlayerChatted:Connect(function(player, message)
        if player ~= LocalPlayer then
            local isCommand = onMessageReceived(message, player)
            if isCommand and PublicFull then
                self:SendToAI(message, 5, player)
            end
        end
    end)
    
    task.spawn(function()
        self:HookExperienceChat(onMessageReceived)
    end)
    
    self.ChatEnabled = true
    return true
end

function ReyAIChat:Disable()
    if self.LegacyConnection then
        self.LegacyConnection:Disconnect()
        self.LegacyConnection = nil
    end
    if self.PlayerChatConnection then
        self.PlayerChatConnection:Disconnect()
        self.PlayerChatConnection = nil
    end
    for _, conn in ipairs(self.ExperienceConnections) do
        conn:Disconnect()
    end
    self.ExperienceConnections = {}
    self.ChatEnabled = false
end

function ReyAIChat:HookExperienceChat(callback)
    local CoreGui = game:GetService("CoreGui")
    local TCS = game:GetService("TextChatService")
    local Players = game:GetService("Players")
    
    while not CoreGui:FindFirstChild("ExperienceChat") do
        task.wait(0.5)
    end
    
    local ec = CoreGui:WaitForChild("ExperienceChat")
    
    local function findComponent(parent, names)
        for _, name in ipairs(names) do
            local child = parent:FindFirstChild(name)
            if child then return child end
        end
        return nil
    end
    
    local appLayout = ec:FindFirstChild("appLayout") or ec:FindFirstChild("AppLayout")
    if not appLayout then
        for _, child in ipairs(ec:GetChildren()) do
            if child:IsA("Frame") then appLayout = child break end
        end
    end
    if not appLayout then return end
    
    local chatInputBar = findComponent(appLayout, {"chatInputBar", "ChatInputBar", "InputBar"})
    if not chatInputBar then return end
    
    local bg = findComponent(chatInputBar, {"Background", "background", "BG"}) or chatInputBar
    local container = findComponent(bg, {"Container", "container", "MainContainer"}) or bg
    local textContainer = findComponent(container, {"TextContainer", "textContainer", "TextBoxFrame"}) or container
    local textBoxContainer = findComponent(textContainer, {"TextBoxContainer", "textBoxContainer", "TextBox"}) or textContainer
    
    local box = findComponent(textBoxContainer, {"TextBox", "Text", "Input"})
    local btn = findComponent(container, {"SendButton", "sendButton", "Send", "Button"})
    
    if not box or not btn then return end
    
    local chip = textContainer:FindFirstChild("TargetChannelChip") or 
                 textContainer:FindFirstChild("Chip") or
                 textContainer:FindFirstChild("RecipientChip")
    
    local function processChat()
        local raw = box.Text
        if raw == "" then return end
        
        box.Text = ""
        
        local isCommand = callback(raw)
        
        if isCommand then
            local channels = TCS:FindFirstChild("TextChannels")
            local sysChan = channels and channels:FindFirstChild("RBXSystem")
            if sysChan and sysChan:IsA("TextChannel") then
                sysChan:DisplaySystemMessage('<font color="#FFD700">[You]</font> ' .. raw)
                if self.IsActive then sendMessage(raw) end
            end
            if self.IsActive then self:SendToAI(raw) end
        else
            local rec = "All"
            if chip and chip:IsA("TextButton") then
                local txt = chip.Text or ""
                local who = string.match(txt, "^%[To%s+(.+)%]$")
                if who and who ~= "" then
                    local lowerWho = string.lower(who)
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if string.lower(plr.DisplayName) == lowerWho then 
                            rec = plr.Name
                            break 
                        end
                    end
                end
            end
            
            local chan = nil
            if rec ~= "All" then
                for _, c in ipairs(TCS.TextChannels:GetChildren()) do
                    if string.find(c.Name, "^RBXWhisper:") and c:FindFirstChild(rec) then
                        chan = c
                        break
                    end
                end
            end
            if not chan then
                chan = TCS.TextChannels:FindFirstChild("RBXGeneral") or 
                       TCS.TextChannels:FindFirstChild("General") or 
                       TCS.TextChannels:FindFirstChild("RBXSystem") or
                       TCS.TextChannels:GetChildren()[1]
            end
            if chan and chan:IsA("TextChannel") then
                chan:SendAsync(raw)
            end
        end
    end
    
    table.insert(self.ExperienceConnections, box.FocusLost:Connect(function(enter)
        if enter then processChat() end
    end))
    table.insert(self.ExperienceConnections, btn.MouseButton1Click:Connect(processChat))
    
    table.insert(self.ExperienceConnections, box:GetPropertyChangedSignal("Text"):Connect(function()
        if box.Text:sub(1, #self.CommandPrefix) == self.CommandPrefix then
            box.TextColor3 = Color3.fromRGB(0, 200, 255)
        else
            box.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end))
end

function ReyAIChat:SendToAI(userInput, maxLoop, fromPlayer)
    maxLoop = maxLoop or 5
    if maxLoop <= 0 then
        self.Notify("error", "ReyAI", "Max internal loops reached")
        return
    end
    
    local HttpService = game:GetService("HttpService")
    local url = "https://ch.at/v1/chat/completions"
    
    local messages = {}
    
    table.insert(messages, {
        role = "system",
        content = BuildSystemPrompt()
    })
    
    if not self.ConversationHistory then
        self.ConversationHistory = {}
    end
    
    for _, msg in ipairs(self.ConversationHistory) do
        table.insert(messages, msg)
    end
    
    table.insert(messages, {
        role = "user",
        content = userInput
    })
    
    local requestBody = HttpService:JSONEncode({
        messages = messages,
        temperature = 0.2,
        max_tokens = 500
    })
    
    local httpFunc = self.HttpFunc or request or http_request or syn.request
    
    local success, result = pcall(function()
        local response = httpFunc({
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = requestBody
        })
        
        local data = HttpService:JSONDecode(response.Body)
        if data.choices and data.choices[1] and data.choices[1].message then
            return data.choices[1].message.content
        end
        return nil
    end)
    
    if not success or not result then
        self.Notify("error", "ReyAI", "Failed")
        return
    end
    
    table.insert(self.ConversationHistory, {role = "user", content = userInput})
    table.insert(self.ConversationHistory, {role = "assistant", content = result})
    print(result.."\n")
    
    local execResult, execError = detectAndExecuteInternal(result)
    if execError then
        print("EXEC ERROR:", execError)
        self.Notify("info", "ReyAI", "Scan error, retrying...")
        
        local errorMessage = string.format([[
[REY_SYSTEM:ERROR]
%s
[/REY_SYSTEM:ERROR]

The code you provided failed to execute. Please fix the error and try again with [REY_INTERNAL:EXEC].
]], execError)
        
        return self:SendToAI(errorMessage, maxLoop - 1, fromPlayer)
    end
    
    if execResult then
        print(execResult)
        self.Notify("info", "ReyAI", "Scanning game...")
        
        local systemMessage = string.format([[
[REY_SYSTEM:DATA]
%s
[/REY_SYSTEM:DATA]

Based on this data, provide the final script for the original request or using format [REY_INTERNAL] to get more data.
]], execResult)
        
        return self:SendToAI(systemMessage, maxLoop - 1, fromPlayer)
    end
    
    local TCS = game:GetService("TextChatService")
    local channels = TCS:FindFirstChild("TextChannels")
    local systemChannel = channels and channels:FindFirstChild("RBXSystem")
    
    local senderPrefix = ""
    if fromPlayer and fromPlayer ~= game.Players.LocalPlayer then
        senderPrefix = "@" .. fromPlayer.Name .. " "
    end
    
    local cleanResult = string.gsub(result, "^%[Rey%]:%s*", "")
    
    local textPart = string.match(cleanResult, "^(.-)%s*```")
    if not textPart then
        textPart = string.match(cleanResult, "^(.-)%s*%-%- Script by ReyAI %| ReyHub")
    end
    local codePart = string.match(cleanResult, "```lua%s*(.-)%s*```")
    if not codePart then
        codePart = string.match(cleanResult, "```%s*(.-)%s*```")
        if not codePart then
            codePart = string.match(cleanResult, "%-%- Script by ReyAI %| ReyHub%s*(.+)$")
        end
    end
    
    if codePart and codePart ~= "" then
        if textPart and systemChannel then
            systemChannel:DisplaySystemMessage('<font color="#9370DB">[Rey]</font> ' .. senderPrefix .. textPart)
            sendMessage("[Rey] " .. senderPrefix .. textPart)
        elseif systemChannel then
            systemChannel:DisplaySystemMessage('<font color="#9370DB">[Rey]</font> ' .. senderPrefix .. 'Executing script...')
            sendMessage("[Rey] " .. senderPrefix .. "Executing Script...")
        end
        
        codePart = string.gsub(codePart, "^%s+", "")
        codePart = string.gsub(codePart, "%s+$", "")
        codePart = string.gsub(codePart, "^```lua%s*", "")
        codePart = string.gsub(codePart, "^```%s*", "")
        codePart = string.gsub(codePart, "%s*```$", "")
        
        if codePart ~= "" then
            self.Notify("success", "ReyAI", "Executing script")
            CodeDisplay:SetCode(codePart)
            if self.OnAIResponse then
                self.OnAIResponse(codePart)
            end
        end
    else
        if systemChannel then
            systemChannel:DisplaySystemMessage('<font color="#9370DB">[Rey]</font> ' .. senderPrefix .. cleanResult)
            sendMessage("[Rey] " .. senderPrefix .. cleanResult)
        end
    end
end

