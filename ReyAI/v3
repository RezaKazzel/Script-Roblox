local function detectAndExecuteInternal(response)
    local pattern = "%[REY_INTERNAL:EXEC%](.-)%[/REY_INTERNAL:EXEC%]"
    local code = string.match(response, pattern)
    
    if not code then
        return nil, nil
    end
    
    local execSuccess, execResult = pcall(function()
        local fn = loadstring(code)
        if not fn then
            error("Failed to compile code")
        end
        return fn()
    end)
    
    if not execSuccess then
        return nil, tostring(execResult)
    end
    
    local function serializeData(data)
        if type(data) == "table" then
            local result = {}
            for k, v in pairs(data) do
                if type(v) == "userdata" then
                    if typeof(v) == "CFrame" then
                        local x, y, z = v:GetComponents()
                        result[k] = {type = "CFrame", x = x, y = y, z = z}
                    elseif typeof(v) == "Vector3" then
                        result[k] = {type = "Vector3", x = v.X, y = v.Y, z = v.Z}
                    elseif typeof(v) == "Vector2" then
                        result[k] = {type = "Vector2", x = v.X, y = v.Y}
                    elseif typeof(v) == "Color3" then
                        result[k] = {type = "Color3", r = v.R, g = v.G, b = v.B}
                    elseif typeof(v) == "Instance" then
                        result[k] = {type = "Instance", name = v.Name, className = v.ClassName}
                    else
                        result[k] = {type = "userdata", class = typeof(v)}
                    end
                elseif type(v) == "table" then
                    result[k] = serializeData(v)
                else
                    result[k] = v
                end
            end
            return result
        elseif type(data) == "userdata" then
            if typeof(data) == "CFrame" then
                local x, y, z = data:GetComponents()
                return {type = "CFrame", x = x, y = y, z = z}
            elseif typeof(data) == "Vector3" then
                return {type = "Vector3", x = data.X, y = data.Y, z = data.Z}
            elseif typeof(data) == "Vector2" then
                return {type = "Vector2", x = data.X, y = data.Y}
            elseif typeof(data) == "Color3" then
                return {type = "Color3", r = data.R, g = data.G, b = data.B}
            elseif typeof(data) == "Instance" then
                return {type = "Instance", name = data.Name, className = data.ClassName}
            else
                return {type = "userdata", class = typeof(data)}
            end
        else
            return data
        end
    end
    
    local serialized = serializeData(execResult)
    
    local jsonSuccess, jsonResult = pcall(function()
        return game:GetService("HttpService"):JSONEncode(serialized)
    end)
    
    if jsonSuccess then
        return jsonResult, nil
    else
        return nil, "Failed to encode result to JSON: " .. tostring(jsonResult)
    end
end

local function SendToAI(userInput, conversationHistory, maxLoop)
    maxLoop = maxLoop or 5
    if maxLoop <= 0 then return nil end
    
    local HttpService = game:GetService("HttpService")
    local url = "https://ch.at/v1/chat/completions"
    
    local messages = {}
    
    table.insert(messages, {
        role = "system",
        content = BuildSystemPrompt()
    })
    
    if conversationHistory then
        for _, msg in ipairs(conversationHistory) do
            table.insert(messages, msg)
        end
    else
        conversationHistory = {}
    end
    
    table.insert(messages, {
        role = "user",
        content = userInput
    })
    
    local requestBody = HttpService:JSONEncode({
        messages = messages,
        temperature = 0.2,
        max_tokens = 500
    })
    
    local response = hR({
        Url = url,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json"
        },
        Body = requestBody
    })
    
    if response and response.Body then
        local data = HttpService:JSONDecode(response.Body)
        if data.choices and data.choices[1] and data.choices[1].message then
            local message = data.choices[1].message.content
            
            table.insert(conversationHistory, {role = "user", content = userInput})
            table.insert(conversationHistory, {role = "assistant", content = message})
            
            local execResult = detectAndExecuteInternal(message)
            if execResult then
                local systemMessage = string.format([[
[REY_SYSTEM:DATA]
%s
[/REY_SYSTEM:DATA]

Based on this data, provide the final script for the original request.
]], execResult)
                
                return SendToAI(systemMessage, conversationHistory, maxLoop - 1)
            end
            
            return message, conversationHistory
        end
    end
    return nil
end

