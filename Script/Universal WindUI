    end
})

-- Proximity Section
local ProximitySection = UtilityTab:Section({
    Title = "Proximity Controls",
    Desc = "Proximity prompt settings",
    Icon = "hand",
    Box = true,
    BoxBorder = true,
    Opened = false
})

local originalDurations = {}

ProximitySection:Toggle({
    Title = "Instant Proximity",
    Desc = "Instant proximity prompts",
    Value = false,
    Flag = "InstantProximity",
    Callback = function(state)
        State.AutoProximityInstant = state
        Utils.Disconnect("AutoProximityInstant")
        
        if State.AutoProximityInstant then
            Utils.AddConnection("AutoProximityInstant", ProximityPromptService.PromptShown:Connect(function(p)
                if not originalDurations[p] then
                    originalDurations[p] = p.HoldDuration
                end
                p.HoldDuration = 0
            end))
        else
            for prompt, originalDuration in pairs(originalDurations) do
                if prompt and prompt.Parent then
                    prompt.HoldDuration = originalDuration
                end
            end
            table.clear(originalDurations)
        end
    end
})

ProximitySection:Toggle({
    Title = "Auto Proximity",
    Desc = "Auto trigger proximity prompts",
    Value = false,
    Flag = "AutoProximity",
    Callback = function(state)
        State.AutoProximityShown = state
        Utils.Disconnect("AutoProximityShown")
        
        if State.AutoProximityShown then
            Utils.AddConnection("AutoProximityShown", ProximityPromptService.PromptShown:Connect(function(p)
                fireproximityprompt(p)
            end))
        end
    end
})

