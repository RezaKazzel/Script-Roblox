-- Farm Toggles
AutoFarmSection:Toggle({
    Title = "AutoFarm V1 (Selected Mob)",
    Desc = "Farm selected mob",
    Value = false,
    Flag = "AutoFarmV1",
    Callback = function(state)
        Utils.Disconnect("AutoFarm")
        RemoveBodyVelocity()
        
        if not state or not State.SelectedMob then return end
        
        local char = LocalPlayer.Character
        local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not playerRoot then return end
        
        local mobFolder = GetMobFolder(State.SelectedMob)
        if not mobFolder then
            WindUI:Notify({
                Title = "Error",
                Content = "Mob folder not found",
                Duration = 3,
                Icon = "alert-circle"
            })
            return
        end
        
        SetupBodyVelocity()
        local currentTarget
        
        Utils.AddConnection("AutoFarm", RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not playerRoot then return end
            
            if not currentTarget or not currentTarget.Parent then
                currentTarget = nil
                for _, mob in ipairs(mobFolder:GetChildren()) do
                    if mob:IsA("Model") and mob.Name == State.SelectedMob then
                        local hum = mob:FindFirstChildWhichIsA("Humanoid")
                        local root = mob:FindFirstChild("HumanoidRootPart")
                        if hum and root and hum.Health > 0 then
                            currentTarget = mob
                            break
                        end
                    end
                end
            end
            
            if not currentTarget then return end
            
            local hum = currentTarget:FindFirstChildWhichIsA("Humanoid")
            local root = currentTarget:FindFirstChild("HumanoidRootPart")
            if not hum or not root or hum.Health <= 0 then
                currentTarget = nil
                return
            end
            
            if State.OneHit then
                ApplyOneHit(currentTarget)
            end
            
            playerRoot.CFrame = getTargetCFrame(root)
            Attack(char)
        end))
    end
})

AutoFarmSection:Toggle({
    Title = "AutoFarm V2 (Improved V1)",
    Desc = "Farm selected mob V2",
    Value = false,
    Flag = "AutoFarmV2",
    Callback = function(state)
        State.AutoFarm = state
        Utils.Disconnect("AutoFarm")
        Utils.Disconnect("AutoFarmLogic")
        RemoveBodyVelocity()
        
        if not state then return end
        if not State.SelectedMob then return end
        
        local char = LocalPlayer.Character
        local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not playerRoot then return end
        
        local mobFolder = GetMobFolder(State.SelectedMob)
        if not mobFolder then
            WindUI:Notify({
                Title = "Error",
                Content = "Mob folder not found",
                Duration = 3,
                Icon = "alert-circle"
            })
            return
        end
        
        SetupBodyVelocity()
        local currentTarget
        
        Utils.StartThread("AutoFarmLogic", function()
            while State.AutoFarm do
                currentTarget = nil
                for _, mob in ipairs(mobFolder:GetChildren()) do
                    if not State.AutoFarm then break end
                    if mob:IsA("Model") and mob.Name == State.SelectedMob then
                        local hum = mob:FindFirstChildWhichIsA("Humanoid")
                        local root = mob:FindFirstChild("HumanoidRootPart")
                        if hum and root and hum.Health > 0 then
                            currentTarget = mob
                            break
                        end
                    end
                end
                
                if currentTarget then
                    if State.OneHit then
                        ApplyOneHit(currentTarget)
                    end
                    Attack(LocalPlayer.Character)
                    task.wait(0.08)
                else
                    task.wait(0.4)
                end
            end
            currentTarget = nil
        end)
        
        Utils.AddConnection("AutoFarm", RunService.Heartbeat:Connect(function()
            if not State.AutoFarm then return end
            if not currentTarget or not currentTarget.Parent then return end
            
            local char = LocalPlayer.Character
            local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
            local root = currentTarget:FindFirstChild("HumanoidRootPart")
            if not playerRoot or not root then return end
            
            playerRoot.CFrame = getTargetCFrame(root)
        end))
    end
})

AutoFarmSection:Toggle({
    Title = "AutoFarm V3 (Nearby)",
    Desc = "Farm nearby enemies",
    Value = false,
    Flag = "AutoFarmV3",
    Callback = function(state)
        Utils.Disconnect("AutoFarmNearby")
        RemoveBodyVelocity()
        if not state then return end
        
        local char = LocalPlayer.Character
        local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not playerRoot then return end
        
        SetupBodyVelocity()
        local target
        local checkDelay = 0.3
        local timer = 0
        
        Utils.AddConnection("AutoFarmNearby", RunService.Heartbeat:Connect(function(dt)
            local char = LocalPlayer.Character
            local playerRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not playerRoot then return end
            
            timer = timer + dt
            if timer >= checkDelay then
                timer = 0
                local nearby = GetNearbyEnemies(State.Range)
                target = nearby and nearby[1]
            end
            
            if not target or not target.Parent then
                target = nil
                return
            end
            
            local hum = target:FindFirstChildWhichIsA("Humanoid")
            local root = target:FindFirstChild("HumanoidRootPart")
            if not hum or not root or hum.Health <= 0 then
                target = nil
                return
            end
            
            if State.OneHit then
                ApplyOneHit(target)
            end
            
            playerRoot.CFrame = getTargetCFrame(root)
            Attack(char)
        end))
    end
})

AutoFarmSection:Slider({
    Title = "Nearby Distance",
    Desc = "Range to detect nearby enemies",
    Value = {Default = 10, Min = 1, Max = 10},
    Step = 1,
    Flag = "NearbyRange",
    Callback = function(value)
        State.Range = value * 10
    end
})

