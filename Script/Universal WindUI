-- Cleanup function
local function CleanupAll()
    for key, conn in pairs(ActiveConnections) do
        if typeof(conn) == "RBXScriptConnection" then
            conn:Disconnect()
        elseif type(conn) == "thread" then
            coroutine.close(conn)
        end
    end
    table.clear(ActiveConnections)
    
    RemoveBodyVelocity()
    
    if FloatPart then
        FloatPart:Destroy()
        FloatPart = nil
    end
    if FloatGUI then
        FloatGUI:Destroy()
        FloatGUI = nil
    end
    
    for key, _ in pairs(State) do
        if type(State[key]) == "boolean" then
            State[key] = false
        end
    end
end

-- Cleanup events
local removeConn
removeConn = Players.PlayerRemoving:Connect(function(leavingPlayer)
    if leavingPlayer == LocalPlayer then
        removeConn:Disconnect()
        CleanupAll()
    end
end)

Window:SelectTab(1)

-- Welcome notification
task.wait(1)
WindUI:Notify({
    Title = "Rey Hub Loaded",
    Content = "Script loaded successfully!",
    Duration = 3,
    Icon = "check"
})