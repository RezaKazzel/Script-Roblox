-- Utility Functions for managing connections
local ActiveConnections = {}
local Utils = {}

function Utils.Disconnect(key)
    local conn = ActiveConnections[key]
    if not conn then return end
    if typeof(conn) == "RBXScriptConnection" then
        conn:Disconnect()
    elseif type(conn) == "thread" then
        coroutine.close(conn)
    end
    ActiveConnections[key] = nil
end

function Utils.AddConnection(key, conn)
    Utils.Disconnect(key)
    ActiveConnections[key] = conn
end

function Utils.StartThread(key, func)
    Utils.Disconnect(key)
    local thread = coroutine.create(func)
    ActiveConnections[key] = thread
    coroutine.resume(thread)
end

-- State management
local State = {
    Distance = 10,
    FarmPosition = "Above",
    SelectedFolder = workspace,
    NPCFolder = workspace,
    Range = 100,
    OneHitHealth = 0.9,
    SelectedMob = nil,
    SelectedTool = nil,
    XRay = false,
    InfJumpDebounce = false,
    TeleportCheck = false,
    OneHit = false,
    AutoClick = false,
    AutoGrab = false,
    AutoProximityShown = false,
    AutoProximityInstant = false,
    AutoFarm = false,
    RestrictAutoFarm = false,
    RestrictedParent = false,
    Noclip = false,
    FloatEnabled = false,
    EdgeJumpEnabled = false
}

-- Helper Functions
local function GetService(name)
    return game:GetService(name)
end

local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild('HumanoidRootPart') or char:FindFirstChild('Torso') or char:FindFirstChild('UpperTorso')
end

local function SetG(path, value)
    local keys = path:split(".")
    local target = getgenv()
    
    for i = 1, #keys - 1 do
        if not target[keys[i]] then
            target[keys[i]] = {}
        end
        target = target[keys[i]]
    end
    target[keys[#keys]] = value
end

local function GetG(path)
    local keys = path:split(".")
    local target = getgenv()
    
    for i = 1, #keys do
        target = target[keys[i]]
        if not target then return nil end
    end
    return target
end

function Utils.randomString()
    local length = math.random(10,20)
    local array = {}
    for i = 1, length do
        array[i] = string.char(math.random(32, 126))
    end
    return table.concat(array)
end

