-- Teleport Section
local TeleportSection = MiscTab:Section({
    Title = "Teleport",
    Desc = "Teleport to players/NPCs",
    Icon = "navigation",
    Box = true,
    BoxBorder = true,
    Opened = true
})

-- Player list function
local function GetPlayerList()
    local players = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(players, player.Name)
        end
    end
    return players
end

local playerDropdown = TeleportSection:Dropdown({
    Title = "Teleport to Player",
    Desc = "Select player to teleport to",
    Values = GetPlayerList(),
    Multi = false,
    Flag = "TeleportPlayer",
    Callback = function(playerName)
        local target = Players:FindFirstChild(playerName)
        local Character = LocalPlayer.Character
        local playerRoot = Character and Character:FindFirstChild("HumanoidRootPart")
        
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and playerRoot then
            local targetPos = target.Character.HumanoidRootPart.Position
            playerRoot.CFrame = CFrame.new(targetPos)
            WindUI:Notify({
                Title = "Teleport",
                Content = "Teleported to " .. playerName,
                Duration = 2,
                Icon = "navigation"
            })
        end
    end
})

TeleportSection:Button({
    Title = "Refresh Player List",
    Icon = "refresh-cw",
    Callback = function()
        playerDropdown:Refresh(GetPlayerList())
    end
})

-- NPC Teleport
local NPCCache = {}
local function GetNPCList()
    local npcs = {}
    NPCCache = {}
    
    for _, obj in ipairs(State.NPCFolder:GetDescendants()) do
        if obj:IsA("Model") and obj.Parent ~= LocalPlayer.Character then
            if obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart then
                if not table.find(npcs, obj.Name) then 
                    table.insert(npcs, obj.Name)
                    NPCCache[obj.Name] = obj
                end
            end
        end
    end
    return npcs
end

local npcDropdown = TeleportSection:Dropdown({
    Title = "Teleport to NPC",
    Desc = "Select NPC to teleport to",
    Values = GetNPCList(),
    Multi = false,
    Flag = "TeleportNPC",
    Callback = function(npcName)
        local playerRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local npc = NPCCache[npcName]
        
        if not npc or npc.Parent == nil then
            npc = nil
            for _, obj in ipairs(State.NPCFolder:GetDescendants()) do
                if obj.Name == npcName and obj:IsA("Model") and (obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart) then
                    npc = obj
                    NPCCache[npcName] = npc
                    break
                end
            end
        end
        
        if npc and playerRoot then
            local targetCFrame = nil
            if npc:FindFirstChild("HumanoidRootPart") then
                targetCFrame = npc.HumanoidRootPart.CFrame
            elseif npc.PrimaryPart then
                targetCFrame = npc.PrimaryPart.CFrame
            else
                for _, part in ipairs(npc:GetChildren()) do
                    if part:IsA("BasePart") then
                        targetCFrame = part.CFrame
                        break
                    end
                end
            end
            
            if targetCFrame then
                playerRoot.CFrame = targetCFrame + Vector3.new(0, 3, 0)
                WindUI:Notify({
                    Title = "Teleport",
                    Content = "Teleported to " .. npcName,
                    Duration = 2,
                    Icon = "navigation"
                })
            end
        end
    end
})

TeleportSection:Button({
    Title = "Refresh NPC List",
    Icon = "refresh-cw",
    Callback = function()
        npcDropdown:Refresh(GetNPCList())
    end
})

