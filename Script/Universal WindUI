    Desc = "Various utility features",
    Icon = "settings",
    Box = true,
    BoxBorder = true,
    Opened = true
})

UtilitySection:Toggle({
    Title = "Auto Click/Attack",
    Desc = "Attack automatically",
    Value = false,
    Flag = "AutoClick",
    Callback = function(state)
        State.AutoClick = state
        Utils.Disconnect("AutoClick")
        
        if State.AutoClick then
            Utils.StartThread("AutoClick", function()
                while State.AutoClick do
                    task.wait()
                    local char = LocalPlayer.Character
                    local x = pcall(Attack, char)
                    if not x then
                        VirtualUser:CaptureController()
                        VirtualUser:Button1Down(Vector2.new(0, 0))
                        VirtualUser:Button1Up(Vector2.new(0, 0))
                    end
                end
            end)
        end
    end
})

UtilitySection:Toggle({
    Title = "Auto Grab Items",
    Desc = "Collect dropped items",
    Value = false,
    Flag = "AutoGrab",
    Callback = function(state)
        State.AutoGrab = state
        Utils.Disconnect("AutoGrab")
        
        if State.AutoGrab then
            Utils.StartThread("AutoGrab", function()
                while State.AutoGrab do
                    task.wait(0.2)
                    local Character = LocalPlayer.Character
                    local playerRoot = Character and Character.HumanoidRootPart
                    if playerRoot then
                        for _, item in ipairs(workspace:GetDescendants()) do
                            if item:IsA("Tool") then
                                local handle = item:FindFirstChild("Handle")
                                if handle then
                                    handle.CFrame = playerRoot.CFrame
                                elseif item:FindFirstChild("CFrame") then
                                    item.CFrame = playerRoot.CFrame
                                elseif item:FindFirstChild("handler") then
                                    item.handler.CFrame = playerRoot.CFrame
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
})

