-- Kill All Buttons
local function createKillButton(name, desc, positionY, killFunc)
    return KillSection:Button({
        Title = name,
        Desc = desc,
        Icon = "zap",
        Callback = function()
            local coreGui = CoreGui:FindFirstChild(name .. "_BUTTON")
            
            if coreGui then coreGui:Destroy() end
            
            local screenGui = Instance.new("ScreenGui")
            screenGui.Name = name .. "_BUTTON"
            screenGui.Parent = CoreGui
            screenGui.ResetOnSpawn = false
            
            local killBtn = Instance.new("TextButton")
            killBtn.Size = UDim2.new(0, 70, 0, 30)
            killBtn.Position = UDim2.new(1, -130, 0, positionY)
            killBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            killBtn.Text = name:gsub("KILL ALL ", "")
            killBtn.TextColor3 = Color3.new(1, 0, 0)
            killBtn.BorderSizePixel = 0
            killBtn.Font = Enum.Font.GothamBold
            killBtn.TextSize = 14
            killBtn.Parent = screenGui
            killBtn.Active = true
            killBtn.Draggable = true
            
            killBtn.MouseButton1Click:Connect(function()
                sethiddenproperty(LocalPlayer, "SimulationRadius", 112412400000)
                sethiddenproperty(LocalPlayer, "MaxSimulationRadius", 112412400000)
                killFunc()
                WindUI:Notify({
                    Title = name,
                    Content = "Executed",
                    Duration = 2,
                    Icon = "zap"
                })
            end)
        end
    })
end

createKillButton("KILL ALL V1", "if Health < Max Health", -10, function()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent.Name ~= LocalPlayer.Name then
            if obj.Health < obj.MaxHealth then
                obj.Health = 0
            end
        end
    end
end)

createKillButton("KILL ALL V2", "if Health < Max Health (BreakJoints)", 30, function()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Parent.Name ~= LocalPlayer.Name and obj:FindFirstChildWhichIsA("Humanoid") then
            if obj.Humanoid.Health < obj.Humanoid.MaxHealth then
                obj:BreakJoints()
            end
        end
    end
end)

createKillButton("KILL ALL V3", "KILL ALL WITHOUT HESITATE", 10, function()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent.Name ~= LocalPlayer.Name then
            obj.Health = 0
        end
    end
end)

KillSection:Toggle({
    Title = "KILL ALL V4",
    Desc = "AUTO KILL BY PERCENTAGE (OP!)",
    Value = false,
    Flag = "KillAllV4",
    Callback = function(state)
        if state then
            local hooked = {}
            
            local function hookHumanoid(humanoid)
                if hooked[humanoid] then return end
                hooked[humanoid] = true
                
                Utils.AddConnection("KILLV4_" .. tostring(humanoid), humanoid.HealthChanged:Connect(function()
                    if humanoid.Parent and humanoid.Parent.Name ~= LocalPlayer.Name and humanoid.Health > 0 then
                        if humanoid.Health / math.max(humanoid.MaxHealth, 1) < State.OneHitHealth then
                            humanoid.Health = 0
                            if humanoid.Parent and humanoid.Parent:IsA("Model") then
                                humanoid.Parent:BreakJoints()
                            end
                        end
                    end
                end))
            end
            
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Humanoid") then
                    hookHumanoid(v)
                end
            end
            
            Utils.AddConnection("KILLV4_ADD", workspace.DescendantAdded:Connect(function(obj)
                if obj:IsA("Humanoid") then
                    task.wait()
                    hookHumanoid(obj)
                end
            end))
        else
            Utils.Disconnect("KILLV4_ADD")
            for key, _ in pairs(ActiveConnections or {}) do
                if string.find(tostring(key), "KILLV4_") then
                    Utils.Disconnect(key)
                end
            end
        end
    end
})

